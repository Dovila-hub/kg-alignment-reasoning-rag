@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix vg: <http://videogame-kg.org/ontology#> .
@prefix vgr: <http://videogame-kg.org/resource/> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

<http://videogame-kg.org/ontology> a owl:Ontology ;
    rdfs:label "Video Game Knowledge Graph Ontology" .

vg:developedBy owl:inverseOf vg:hasDeveloper .

vg:hasGenre a owl:ObjectProperty ;
    rdfs:domain vg:Game ;
    rdfs:range vg:Genre .

vg:hasPlatform a owl:ObjectProperty ;
    rdfs:domain vg:Game ;
    rdfs:range vg:Platform .

vg:hasTitle a owl:DatatypeProperty ;
    rdfs:domain vg:Game ;
    rdfs:range xsd:string .

vg:publishedBy owl:inverseOf vg:hasPublisher .

vg:releaseYear a owl:DatatypeProperty ;
    rdfs:domain vg:Game ;
    rdfs:range xsd:gYear .

vg:salesMillions a owl:DatatypeProperty ;
    rdfs:domain vg:Game ;
    rdfs:range xsd:float .

