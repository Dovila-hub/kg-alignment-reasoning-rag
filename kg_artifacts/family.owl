<?xml version="1.0"?>
<rdf:RDF xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
         xmlns:owl="http://www.w3.org/2002/07/owl#"
         xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#"
         xmlns:xsd="http://www.w3.org/2001/XMLSchema#"
         xmlns:fam="http://family.owl#"
         xml:base="http://family.owl">

  <owl:Ontology rdf:about="http://family.owl"/>

  <!-- Classes -->
  <owl:Class rdf:about="http://family.owl#Person"/>

  <!-- Properties -->
  <owl:ObjectProperty rdf:about="http://family.owl#hasParent">
    <rdfs:domain rdf:resource="http://family.owl#Person"/>
    <rdfs:range rdf:resource="http://family.owl#Person"/>
  </owl:ObjectProperty>

  <owl:ObjectProperty rdf:about="http://family.owl#hasGrandparent">
    <rdfs:domain rdf:resource="http://family.owl#Person"/>
    <rdfs:range rdf:resource="http://family.owl#Person"/>
  </owl:ObjectProperty>

  <owl:ObjectProperty rdf:about="http://family.owl#hasSibling">
    <rdfs:domain rdf:resource="http://family.owl#Person"/>
    <rdfs:range rdf:resource="http://family.owl#Person"/>
  </owl:ObjectProperty>

  <!-- Individuals -->
  <owl:NamedIndividual rdf:about="http://family.owl#Alice">
    <rdf:type rdf:resource="http://family.owl#Person"/>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="http://family.owl#Bob">
    <rdf:type rdf:resource="http://family.owl#Person"/>
    <fam:hasParent rdf:resource="http://family.owl#Alice"/>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="http://family.owl#Carol">
    <rdf:type rdf:resource="http://family.owl#Person"/>
    <fam:hasParent rdf:resource="http://family.owl#Alice"/>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="http://family.owl#Dave">
    <rdf:type rdf:resource="http://family.owl#Person"/>
    <fam:hasParent rdf:resource="http://family.owl#Bob"/>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="http://family.owl#Eve">
    <rdf:type rdf:resource="http://family.owl#Person"/>
    <fam:hasParent rdf:resource="http://family.owl#Bob"/>
  </owl:NamedIndividual>

</rdf:RDF>